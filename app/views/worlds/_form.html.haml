= form_with model: world do |form|
  - if world.errors.any?
    .form-errors
      = pluralize(world.errors.count, "error")
      prevented this world from being saved:
      %ul
        - world.errors.full_messages.each do |message|
          %li= message

  .form-field
    = form.label :title
    = form.text_field :title, autofocus: true

  .form-field
    = form.label :core_concept
    = form.text_area :core_concept, rows: 6

  = form.button "Save"
